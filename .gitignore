# ==========================================
# NetLaunch Enterprise Monorepo .gitignore
# ==========================================

# Dependencies & Node
node_modules
.pnp
.pnp.js
package-lock.json
yarn.lock
pnpm-lock.yaml.lock

# Turborepo & Build Cache
.turbo
.cache
.npm
*.tsbuildinfo

# Next.js & Frontend Build Outputs
.next
out
build
dist
.vite

# Environment & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert

# Logs & Debug Artifacts
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Database & Local Docker Volumes
postgres-data/
redis-data/
minio-data/
*.sqlite
*.sqlite3
*.sqlite3-journal

# IDE & Editor Directories
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea
.fleet
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS & System Metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Testing & Coverage
coverage/
.nyc_output/
reports/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Temporary & Scratch Files
tmp/
temp/
*.tmp
*.bak
*.orig
