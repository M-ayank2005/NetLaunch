{
  "name": "netlaunch-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade deployment platform architecture (Vercel/Netlify alternative)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:push": "pnpm --filter @netlaunch/database db:push",
    "db:migrate": "pnpm --filter @netlaunch/database db:migrate",
    "db:studio": "pnpm --filter @netlaunch/database db:studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.0.0"
  }
}
