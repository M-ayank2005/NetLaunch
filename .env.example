# ==========================================
# NetLaunch Environment Configuration
# ==========================================

# Current Environment
NODE_ENV=development
PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# PostgreSQL Database Connection
DATABASE_URL="postgresql://netlaunch:netlaunch_secret_2026@localhost:5432/netlaunch_db?schema=public"

# Redis Connection (BullMQ, Caching, PubSub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=netlaunch_redis_pass_2026

# GitHub OAuth App Configuration (User Authentication)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/github/callback

# GitHub App Configuration (Repository & Build Permissions)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_CLIENT_ID=your_github_app_client_id
GITHUB_APP_CLIENT_SECRET=your_github_app_client_secret
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYour GitHub App Private Key Here\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret_here

# Security & JWT Token Secrets
JWT_SECRET=super_secret_netlaunch_jwt_key_2026
SESSION_COOKIE_NAME=netlaunch_session

# Object Storage (MinIO Local Emulator / Cloudflare R2 / AWS S3)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=netlaunch_minio_admin
STORAGE_SECRET_KEY=netlaunch_minio_secret_2026
STORAGE_BUCKET_ARTIFACTS=netlaunch-artifacts
STORAGE_BUCKET_LOGS=netlaunch-logs
STORAGE_REGION=us-east-1
